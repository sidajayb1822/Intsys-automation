      break; 
    }
  }
  
  if(!deleted) throw new Error(`Marketing Lead not found for ID: ${obj.id}`);

  const intSheet = ss.getSheetByName('Interactions');
  const intData = intSheet.getDataRange().getValues();
  for(let j = intData.length - 1; j >= 1; j--) {
    if(String(intData[j][1]).trim() === String(obj.id).trim()) {
