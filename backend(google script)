  if (!SPREADSHEET_ID || SPREADSHEET_ID === "PASTE_YOUR_SHEET_ID_HERE") {
    throw new Error("You must paste your SPREADSHEET_ID at the top of the file before running setup().");
  }

  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  checkAndFixHeaders(ss); 
  
  if (ss.getSheetByName('Users').getLastRow() <= 1) {
    ss.getSheetByName('Users').appendRow(['Admin', 'admin@example.com', 'admin123', 'Admin', 0, 0]);
  }
  if (ss.getSheetByName('Companies').getLastRow() <= 1) {
