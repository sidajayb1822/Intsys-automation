function saveSalesTargets(data) {
    const sheet = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName('Settings');
    const rows = sheet.getDataRange().getValues();
    let pFound = false, rFound = false, cFound = false, wFound = false;

    for (let i = 1; i < rows.length; i++) {
        if (rows[i][0] === 'yearlyPipelineTarget') { sheet.getRange(i+1, 2).setValue(data.pipeline); pFound = true; }
        if (rows[i][0] === 'yearlyRevenueTarget') { sheet.getRange(i+1, 2).setValue(data.revenue); rFound = true; }
        if (rows[i][0] === 'yearlyConvertedTarget') { sheet.getRange(i+1, 2).setValue(data.converted); cFound = true; }
        if (rows[i][0] === 'yearlyWonFromConvertedTarget') { sheet.getRange(i+1, 2).setValue(data.wonFromConverted); wFound = true; }
    }

    if (!pFound) sheet.appendRow(['yearlyPipelineTarget', data.pipeline]);
    if (!rFound) sheet.appendRow(['yearlyRevenueTarget', data.revenue]);
    if (!cFound) sheet.appendRow(['yearlyConvertedTarget', data.converted]);
    if (!wFound) sheet.appendRow(['yearlyWonFromConvertedTarget', data.wonFromConverted]);

    return true;
}

