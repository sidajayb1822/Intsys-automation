  return true;
}

function updateCompanyStatus(obj) {
  const sheet = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName('Companies');
  const data = sheet.getDataRange().getValues();
  let found = false;
  for(let i=1; i<data.length; i++) {
    if(String(data[i][0]).trim() === String(obj.companyId).trim()) {
      if (data[i][4] === obj.newStatus) return true; 
      sheet.getRange(i+1, 5).setValue(obj.newStatus); 
      found = true;
      break;
    }
  }
  if(found) SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName('Interactions').appendRow([new Date(), String(obj.companyId).trim(), 'Status Change', `Status changed to ${obj.newStatus}`, obj.employeeEmail, '', '', 'Completed']);
  return found;
}

function logInteraction(obj) {
  SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName('Interactions').appendRow([
    new Date(), String(obj.companyId).trim(), obj.interactionType, obj.description, obj.employeeEmail, obj.nextAction || '', obj.nextActionDate || '', 'Pending'
  ]);
  return true;
}

function authenticateUser(email, pass) { 
  const sheet = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName('Users');
  if(!sheet) return null;
  const data = sheet.getDataRange().getValues();
  for (let i = 1; i < data.length; i++) {
    if (String(data[i][1]).trim().toLowerCase() === String(email).trim().toLowerCase() && String(data[i][2]).trim() === String(pass).trim()) {
      return { name: data[i][0], email: data[i][1], role: data[i][3] };
    }
  }
  return null;
}

function addUser(obj) { 
  SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName('Users').appendRow([obj.name, obj.email, obj.password, obj.role, 0, 0]); 
  return true; 
}

function deleteUser(email) { 
  const sheet = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName('Users');
  const data = sheet.getDataRange().getValues();
  for (let i = 1; i < data.length; i++) {
    if (String(data[i][1]).trim() === String(email).trim()) { sheet.deleteRow(i + 1); break; }
  }
  return true;
}

// --- Data Setup Engine ---
