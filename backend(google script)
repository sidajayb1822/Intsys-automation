}

function updateSalesCompany(obj) {
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const sheet = ss.getSheetByName('SalesCompanies');
  const data = sheet.getDataRange().getValues();
  let updated = false;
  
  for(let i=1; i<data.length; i++) {
    if(String(data[i][0]).trim() === String(obj.id).trim()) { 
      sheet.getRange(i+1, 2).setValue(obj.companyName);
      sheet.getRange(i+1, 3).setValue(obj.location);
      sheet.getRange(i+1, 4).setValue(obj.leadSource);
      sheet.getRange(i+1, 7).setValue(obj.pocs || obj.pocDetails || '[]');
      updated = true;
      break;
    }
  }
  
  if(!updated) throw new Error(`Sales Lead not found for ID: ${obj.id}`);

  if (String(obj.id).trim().startsWith("COMP-")) {
      const compSheet = ss.getSheetByName('Companies');
      if (compSheet) {
          const compData = compSheet.getDataRange().getValues();
          for(let j=1; j<compData.length; j++) {
              if(String(compData[j][0]).trim() === String(obj.id).trim()) {
                  compSheet.getRange(j+1, 2).setValue(obj.companyName);
                  compSheet.getRange(j+1, 3).setValue(obj.location);
                  compSheet.getRange(j+1, 4).setValue(obj.leadSource);
                  compSheet.getRange(j+1, 8).setValue(obj.pocs || obj.pocDetails || '[]');
                  break;
              }
          }
      }
  }

  return true;
}

