    ss.getSheetByName('Interactions').appendRow([new Date(), 'COMP-001', 'Status Change', 'Marketing Lead created with status Lead Generated', 'admin@example.com', '', '', 'Completed']);
  }

  const defaultSheet = ss.getSheetByName("Sheet1");
  if (defaultSheet && ss.getSheets().length > 1) {
    ss.deleteSheet(defaultSheet);
  }
}