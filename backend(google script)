// --- Marketing Functions ---
function toggleNextStep(obj) {
  const sheet = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName('Interactions');
  const data = sheet.getDataRange().getValues();
  
  for(let i=1; i<data.length; i++) {
    let sheetDate = data[i][6];
    let matchDate = false;
    if (sheetDate instanceof Date) {
        const sheetIso = sheetDate.toISOString().split('T')[0];
        matchDate = sheetIso === obj.nextActionDate;
    } else if (typeof sheetDate === 'string') {
        matchDate = sheetDate.includes(obj.nextActionDate);
    }

    if(String(data[i][1]).trim() === String(obj.companyId).trim() && data[i][5] === obj.nextAction && matchDate) {
      let status = 'Completed';
      let dueDate = sheetDate instanceof Date ? sheetDate : new Date(obj.nextActionDate);
      let today = new Date(); today.setHours(0,0,0,0); dueDate.setHours(0,0,0,0);
      if (today > dueDate) status = 'Completed Late';
      sheet.getRange(i+1, 8).setValue(status);
      return true;
    }
  }
  return false;
}

